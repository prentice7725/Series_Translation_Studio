# Translation provider: mock or vertex
STS_TRANSLATION_PROVIDER=mock

# Vertex AI Gemini settings
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TIMEOUT_MS=60000

# Google Application Default Credentials service account JSON path
GOOGLE_APPLICATION_CREDENTIALS=

# Optional local workspace override
STS_WORKSPACE_DIR=
